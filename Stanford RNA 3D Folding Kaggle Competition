    "    \n",
    "    print(f\"\\n   Prediction {i}:\")\n",
    "    print(f\"      X: {non_zero_x}/{len(submission_df)} non-zero ({non_zero_x/len(submission_df)*100:.1f}%)\")\n",
    "    print(f\"      Y: {non_zero_y}/{len(submission_df)} non-zero ({non_zero_y/len(submission_df)*100:.1f}%)\")\n",
