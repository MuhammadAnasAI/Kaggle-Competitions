    "for i, pred in enumerate(test_preds):\n",
    "    print(f\"      Prediction {i+1} shape: {pred.shape}\")\n",
    "\n",
    "# Generate full submission\n",
    "submission_df = create_submission(ensemble, test_subset, 'sample_submission.csv')\n",
